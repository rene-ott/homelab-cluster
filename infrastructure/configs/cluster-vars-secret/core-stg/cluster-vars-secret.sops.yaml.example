# EXAMPLE ONLY — copy to cluster-vars-secret.sops.yaml, fill in real values, then encrypt:
#   cp infrastructure/configs/cluster-vars-secret/core-stg/cluster-vars-secret.sops.yaml.example \
#      infrastructure/configs/cluster-vars-secret/core-stg/cluster-vars-secret.sops.yaml
#   # Delete this comment block from the copy first — SOPS only encrypts
#   # data/stringData values (see .sops.yaml's encrypted_regex), so comments stay
#   # in plaintext forever and this "EXAMPLE ONLY" header would be misleading
#   # left in the real, committed secret.
#   ./scripts/sops.sh   # select "Encrypt" and pick the copied file
#
# This is the core-stg (staging) cluster's copy. domain_apps MUST be distinct from
# the core (prod) cluster's domain_apps so the two clusters don't request the same
# wildcard cert or write conflicting DNS-01 records.
#
# Kept as a plaintext template so the secret can be recreated from scratch if the
# age private key is ever lost (see "lost private key" case in sops.sh Rotate).
apiVersion: v1
kind: Secret
metadata:
    name: cluster-vars-secret
    namespace: flux-system
type: Opaque
stringData:
    domain_apps: staging.apps.example.com
    letsencrypt_email: you@example.com
